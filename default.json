{
  "extends": ["config:best-practices"],
  "semanticCommits": "enabled",
  "prConcurrentLimit": 5,
  "labels": ["dependencies"],
  "ignoreDeps": ["node"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "GitHub Actions (non-major)"
    },
    {
      "matchSourceUrls": ["https://github.com/triggerdotdev/trigger.dev"],
      "groupName": "trigger.dev monorepo packages"
    },
    {
      "matchDatasources": [
        "nuget"
      ],
      "description": "Group all NatchOS packages together",
      "groupName": "NatchOS",
      "patch": {
        "enabled": true
      },
      "matchPackageNames": [
        "NatchOS.{/,}**"
      ]
    },
    {
      "matchDatasources": [
        "nuget"
      ],
      "description": "Group all NatchCms packages together",
      "groupName": "NatchCms",
      "patch": {
        "enabled": true
      },
      "matchPackageNames": [
        "NatchCms.{/,}**"
      ]
    },
    {
      "matchDatasources": [
        "nuget"
      ],
      "description": "Group all Natch packages together",
      "groupName": "Natch",
      "patch": {
        "enabled": true
      },
      "matchPackageNames": [
        "Natch.{/,}**"
      ]
    },
    {
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": ["Autofac.Extensions.DependencyInjection", "NSubstitute"],
      "abandonmentThreshold": null
    },
    {
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "FluentAssertions"
      ],
      "replacementName": "AwesomeAssertions",
      "description": "FluentAssertions is forbidden; replace with AwesomeAssertions."
    },
    {
      "matchDatasources": [
        "nuget"
      ],
      "matchPackageNames": [
        "AutoMapper"
      ],
      "replacementName": "Mapster",
      "description": "AutoMapper is forbidden; replace with Mapster."
    }
  ],
  "timezone": "CET",
  "schedule": [
    "* 0-7 * * 1-5"
  ],
  "abandonmentThreshold": "2 years"
}
